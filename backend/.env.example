# ─────────────────────────────────────────────────────────────
# AICEO — backend env template
# Copy to .env and fill in real values. Do NOT commit real keys.
# ─────────────────────────────────────────────────────────────

# ─── Core ───────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Supabase (required) ────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
# Service role key — full DB access, server-side only, NEVER ship to client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# JWT secret — verifies access tokens locally (no GoTrue round-trip).
# Found in Supabase dashboard → Project Settings → API → JWT Settings →
# "JWT Secret". Without this, requireAuth falls back to a network call
# that 401s when GoTrue rate-limits or has a transient hiccup.
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ─── LLM providers (required — app won't run without these) ─
# Anthropic Claude — used by every marketing agent (landing page,
# newsletter, carousel, etc.)
ANTHROPIC_API_KEY=sk-ant-api03-...
# xAI Grok — AI CEO orchestrator brain + web research
XAI_API_KEY=xai-...
# OpenAI — image generation fallback
OPENAI_API_KEY=sk-...
# Gemini — alt model for some carousel/image flows (optional)
GEMINI_API_KEY=

# ─── Stripe (required for billing & webhooks) ──────────────
# Secret key — live (sk_live_...) in prod, test (sk_test_...) in dev
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret — unique per endpoint, starts with whsec_
# Create the endpoint at https://dashboard.stripe.com/webhooks pointing
# to <backend-url>/api/webhooks/stripe and copy the "Signing secret".
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — one per (plan, tier) combo. Get them from
# https://dashboard.stripe.com/prices after creating the subscription
# products. The Checkout Session endpoint looks these up by name:
# STRIPE_PRICE_<PLAN>_<STANDARD|BOOST>  where <PLAN> = uppercase plan id.
STRIPE_PRICE_COMPLETE_STANDARD=price_...
STRIPE_PRICE_COMPLETE_BOOST=price_...
STRIPE_PRICE_DIAMOND_STANDARD=price_...
STRIPE_PRICE_DIAMOND_BOOST=price_...
# One-time SETUP fee Price IDs (mode=payment in Stripe). The new 4-step
# signup funnel charges this BEFORE the recurring subscription, so both
# must be configured for any new signup to work.
STRIPE_PRICE_COMPLETE_SETUP=price_...
STRIPE_PRICE_DIAMOND_SETUP=price_...

# Instalment plans for the setup fee. Each is a recurring monthly Stripe
# Price configured to bill for N cycles total (use a Subscription
# Schedule or set cancel_at on the subscription after N cycles in the
# Stripe Dashboard). The fee shown on the UI is PER MONTH, not total —
# so for 3x at $100/mo extra the customer pays an additional $300;
# for 6x at $125/mo extra they pay an additional $750.
# Per-payment amounts are rounded to whole dollars on the funnel UI;
# set the Stripe Price unit_amount to the same rounded number so the
# customer's first invoice matches what they saw on the plan page.
#   CORE (internal id: complete) base $2997
#     3x  $1099 / month, $3297 total
#     6x   $625 / month, $3747 total
#   DIAMOND  base $3997
#     3x  $1432 / month, $4297 total
#     6x   $791 / month, $4747 total
# All optional — when an entry is missing the corresponding instalment
# card returns a clear "not configured" error if the user picks it.
STRIPE_PRICE_COMPLETE_INSTALL_3X=
STRIPE_PRICE_COMPLETE_INSTALL_6X=
STRIPE_PRICE_DIAMOND_INSTALL_3X=
STRIPE_PRICE_DIAMOND_INSTALL_6X=

# ─── Calendly (used by signup booking step in the new funnel) ────────
# Public Calendly event URL embedded in an iframe. CALENDLY_URL is the
# generic fallback; the per-plan ones override it when set.
# Backend uses CALENDLY_URL_* (no VITE_ prefix) to write the link into
# the booking-invite email. The frontend reads VITE_CALENDLY_URL_* from
# the root .env / Netlify build env.
CALENDLY_URL=
CALENDLY_URL_COMPLETE=
CALENDLY_URL_DIAMOND=

# ─── Platform transactional email ──────────────────────────
# Provider order: ZorroMail (primary) → Resend (fallback on missing key
# or 5xx). Both are HTTPS APIs, so Railway's SMTP block doesn't apply.
#
# ZorroMail (primary) — https://zorromail.app
# Create a Transactional → API key in the dashboard, verify your sending
# domain first (otherwise sends return 422). Docs live in
# docs/zorromail-transactional-llm.md.
ZORROMAIL_API_KEY=tk_live_your_key_here
# Verified sending address on ZorroMail (e.g. hello@yourdomain.com).
# Must match a verified domain in the ZorroMail dashboard.
ZORROMAIL_FROM_EMAIL=hello@yourdomain.com
#
# Resend (fallback) — https://resend.com — free 100 emails/day.
RESEND_API_KEY=re_your_key_here
# Verified "from" address on Resend (e.g. inbox@yourdomain.com)
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optional single override — when set, the platform emails use this as
# the From address in preference to ZORROMAIL_FROM_EMAIL / RESEND_FROM_EMAIL.
# Useful when you want a friendlier team address (e.g. team@aiceo.com).
PLATFORM_EMAIL_FROM=
# Optional — brand label used in email templates. Defaults to "AI CEO".
PLATFORM_BRAND_NAME=
# Optional — Stripe Billing Portal URL. If set, the "update your card"
# link in payment-failure emails deep-links here. Otherwise it falls
# back to the in-app /settings/billing route.
STRIPE_BILLING_PORTAL_URL=

# ─── Outlier Detector (all optional — features degrade gracefully) ─
# YouTube Data API for YT creators
YOUTUBE_API_KEY=
# RapidAPI for TikTok + Instagram primary data source
RAPIDAPI_KEY=
# Apify token — Instagram + LinkedIn fallback / primary scraper
APIFY_TOKEN=
# Optional actor overrides (defaults live in each service file)
APIFY_INSTAGRAM_ACTOR=
APIFY_LINKEDIN_PROFILE_ACTOR=
APIFY_LINKEDIN_POSTS_ACTOR=

# ─── Microsoft / Outlook OAuth (for Email → connect Outlook) ──
# Register at https://portal.azure.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── LinkedIn OAuth (for Content → publish to LinkedIn) ────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── BooSend (DM automation) ───────────────────────────────
BOOSEND_API_KEY=

# ─── Misc ──────────────────────────────────────────────────
# Landing page agent service URL (separate Railway service)
LANDING_AGENT_URL=https://landing-page-agent-production-b414.up.railway.app
# Optional — required only if you invoke yt-dlp with a non-default path
YTDLP_PATH=
# Railway auto-sets this in prod; only override locally if needed
API_BASE_URL=
